# Application
PORT=8000
LOG_LEVEL=info
MODEL_ROOT=models

# AWS deployment
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default
S3_MODEL_BUCKET=replace-with-model-bucket
S3_MODEL_PREFIX=models
CODEBUILD_PROJECT_NAME=mlops-yolov5-deploy
ECR_REPOSITORY_URI=123456789012.dkr.ecr.us-east-1.amazonaws.com/mlops-yolov5
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:mlops-yolov5-deployments
MODEL_TASK=object_detection
MODEL_OUTPUT_PATH=models/object_detection/model.onnx

# Heroku deployment
ENABLE_HEROKU_DEPLOY=false
HEROKU_APP_NAME=replace-with-heroku-app-name
HEROKU_API_KEY=set-this-in-a-secret-manager-not-in-source-control
