# Application
PORT=8000
LOG_LEVEL=info
MODEL_ROOT=models

# AWS deployment
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default
S3_MODEL_BUCKET=replace-with-model-bucket
S3_MODEL_PREFIX=models
CODEBUILD_PROJECT_NAME=mlops-yolov5-deploy
ECR_REPOSITORY_URI=123456789012.dkr.ecr.us-east-1.amazonaws.com/mlops-yolov5
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:mlops-yolov5-deployments
MODEL_OUTPUT_PATH=models/object_detection/yolov5s.onnx
SEGMENTATION_MODEL_OUTPUT_PATH=models/segmentation/yolov5s-seg.onnx
YOLOV5_REF=v7.0

# Hugging Face Docker Space
ENABLE_HF_DEPLOY=false
HF_SPACE_ID=your-hf-username/mlops-yolov5
HF_TOKEN=set-this-in-aws-secrets-manager-not-in-source-control
